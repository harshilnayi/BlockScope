# ===================================
# BLOCKSCOPE — Environment Template
# ===================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# IMPORTANT: Generate unique secret keys using:
#   python -c "import secrets; print(secrets.token_urlsafe(64))"
#
# See DEPLOYMENT.md for full setup instructions.
# ===================================

# ─── Application ───
APP_NAME=BlockScope
APP_VERSION=1.0.0
ENVIRONMENT=development          # development | staging | production
DEBUG=False                      # True only in development
LOG_LEVEL=INFO                   # DEBUG | INFO | WARNING | ERROR

# ─── Server ───
HOST=0.0.0.0
PORT=8000
WORKERS=4                        # Uvicorn workers (1 in dev, 4+ in prod)
RELOAD=False                     # True only in development

# ─── Database (PostgreSQL) ───
POSTGRES_USER=blockscope_dev
POSTGRES_PASSWORD=               # ⚠️  REQUIRED — set a strong password
POSTGRES_DB=blockscope_dev
DB_PORT=5432
DATABASE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@db:${DB_PORT}/${POSTGRES_DB}
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=10
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=3600
DB_ECHO=False                    # True to log SQL queries (dev only)

# ─── Redis ───
REDIS_URL=redis://redis:6379/0
REDIS_PORT=6379
REDIS_PASSWORD=                  # Set in production
REDIS_MAX_CONNECTIONS=20

# ─── Security ───
# ⚠️  REQUIRED — Generate unique values for each deployment:
#   python -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=
JWT_SECRET_KEY=
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30

# ─── API Key ───
API_KEY_HEADER_NAME=X-API-Key
API_KEY_LENGTH=32
API_KEY_PREFIX=bsc_

# ─── CORS ───
CORS_ORIGINS=["http://localhost:5173"]
CORS_ALLOW_CREDENTIALS=True
CORS_ALLOW_METHODS=["GET","POST","PUT","DELETE","OPTIONS"]
CORS_ALLOW_HEADERS=["*"]

# ─── Rate Limiting ───
RATE_LIMIT_ENABLED=True
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_PER_HOUR=1000
RATE_LIMIT_PER_DAY=10000

# ─── File Upload ───
MAX_UPLOAD_SIZE=10485760         # 10 MB
ALLOWED_EXTENSIONS=[".sol",".vy"]
UPLOAD_FOLDER=./uploads

# ─── Slither (Static Analysis) ───
SLITHER_TIMEOUT=60
SLITHER_MAX_CONCURRENT=2
SLITHER_PATH=slither
SOLC_VERSION=0.8.20

# ─── Caching ───
CACHE_SCAN_RESULTS=True
CACHE_TTL=1800                   # 30 minutes
CACHE_PREFIX=scan:

# ─── Logging ───
LOG_FILE_ENABLED=True
LOG_FILE_PATH=./logs/blockscope.log
LOG_JSON_FORMAT=True             # JSON in production
LOG_REQUESTS=False
LOG_RESPONSES=False
LOG_REQUEST_BODY=False           # Never in production

# ─── Performance ───
GZIP_MINIMUM_SIZE=1000
GZIP_COMPRESSION_LEVEL=6

# ─── Feature Flags ───
ENABLE_REGISTRATION=True
ENABLE_API_DOCS=False            # Disable in production
ENABLE_METRICS=True

# ─── Admin ───
ADMIN_EMAIL=admin@blockscope.io
ADMIN_USERNAME=admin
ADMIN_PASSWORD=                  # ⚠️  REQUIRED — set a strong password

# ─── Testing ───
TESTING=False
TEST_DATABASE_URL=sqlite:///./test.db
