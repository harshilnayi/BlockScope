[run]
source =
    app
    analysis
omit =
    backend/tests/*
    tests/*
    */__pycache__/*
    */migrations/*
    */alembic/*
    analysis/tests/*
    backend/analysis/tests/*
    backend/cli/*
    cli/*
    app/core/auth.py
    app/core/rate_limit.py
    app/core/security.py

[report]
exclude_lines =
    pragma: no cover
    def __repr__
    if __name__ == .__main__\.
    raise NotImplementedError
    pass
    except ImportError
    \.\.\.
    if TYPE_CHECKING
show_missing = True
precision = 2
fail_under = 80
