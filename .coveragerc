[run]
source =
    backend/app
    backend/analysis
omit =
    backend/tests/*
    backend/venv/*
    */__pycache__/*
    */migrations/*
    */alembic/*
    backend/analysis/tests/*
    backend/cli/*

[report]
exclude_lines =
    pragma: no cover
    def __repr__
    if __name__ == .__main__\.
    raise NotImplementedError
    pass
    except ImportError
    \.\.\.
    if TYPE_CHECKING
show_missing = True
precision = 2
fail_under = 80
